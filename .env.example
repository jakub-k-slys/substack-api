# Environment variables for running E2E tests
# Copy this file to .env and fill in your actual values

# Required: Bearer token for the substack-gateway
# Build it from your browser cookies after logging into substack.com:
#   btoa(JSON.stringify({ substack_sid: '<substack.sid cookie>', connect_sid: '<connect.sid cookie>' }))
SUBSTACK_TOKEN=your-token-here

# Required: The hostname of your Substack publication
# Example: yoursite.substack.com
SUBSTACK_HOSTNAME=yoursite.substack.com

# Optional: Override the gateway URL (defaults to https://substack-gateway.vercel.app)
# GATEWAY_URL=http://localhost:5001
