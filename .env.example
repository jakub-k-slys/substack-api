# Environment variables for running E2E tests
# Copy this file to .env and fill in your actual values

# Required: Your substack.sid session cookie value
# Obtain this from your browser's cookies after logging into Substack (substack.com)
SUBSTACK_SID=your-substack-sid-here

# Required: Your connect.sid session cookie value
# Obtain this from your browser's cookies after logging into Substack (substack.com)
CONNECT_SID=your-connect-sid-here

# Required: The hostname of your Substack publication
# Example: yoursite.substack.com
SUBSTACK_HOSTNAME=yoursite.substack.com

# Optional: Override the gateway URL (defaults to https://substack-gateway.vercel.app)
# GATEWAY_URL=http://localhost:5001
